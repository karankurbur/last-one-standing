# Server HMAC secret for challenge integrity (required by mppx)
# Generate one with: openssl rand -hex 32
MPP_SECRET_KEY=

# Private key of the server's settlement wallet.
# This wallet closes payment channels and pays out winners on-chain.
# Must hold USDC.e on Tempo to cover gas (feeToken) and payouts.
SETTLE_PRIVATE_KEY=

# (Optional) HTTP port for the game server. Default: 3000
# PORT=3000

# (Optional) Max lives per player. Default: 3
# MAX_LIVES=3
